{
  "name": "kshuri-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Kshuri Grooming Marketplace — Backend API Server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run --project=unit --project=integration",
    "test:integration": "vitest run --project=integration",
    "test:unit": "vitest run --project=unit",
    "test:db": "vitest run --project=integration-db",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project=unit --project=integration --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@kshuri/contracts": "*",
    "@sentry/node": "^10.48.0",
    "@sentry/profiling-node": "^10.48.0",
    "@types/cookie-parser": "^1.4.10",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv-flow": "^4.1.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "express-slow-down": "^3.1.0",
    "file-type": "^16.5.4",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^9.14.1",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "resend": "^6.12.2",
    "tsx": "^4.19.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "node-tesseract-ocr": "^2.2.1",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
